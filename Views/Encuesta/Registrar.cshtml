<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Registrar Encuesta</title>
    @Styles.Render("~/Content/css")
</head>
<body>

    <link href="@Url.Content("~/Content/encuesta_crear.css")" rel="stylesheet" />

    <div class="survey-container">

        <div class="survey-header">
            <h3 class="survey-title">Registrar encuesta</h3>
        </div>

        @if (ViewBag.Creado == null)
        {
            <form action="@Url.Action("RegistrarEncuesta","Encuesta")" method="post" class="survey-form">

                <!-- Datos generales -->
                <div class="form-group">
                    <label>Nombre</label>
                    <input type="text" class="input-text" name="Nombre"
                           value="@(ViewBag.Nombre != null ? ViewBag.Nombre : "")" required />
                </div>

                <div class="form-group">
                    <label>Descripción</label>
                    <input type="text" class="input-text" name="Descripcion"
                           value="@(ViewBag.Descripcion != null ? ViewBag.Descripcion : "")" required />
                </div>

                @if (ViewBag.Mensaje != null)
                {
                    <div class="alert">
                        @ViewBag.Mensaje
                    </div>
                }

                <!-- Angular -->
                <div ng-app="encuestaApp" ng-controller="encuestaCtrl" class="questions-section">

                    <h3 class="section-title">Preguntas</h3>

                    <div ng-repeat="p in encuesta.preguntas" class="question-card">

                        <label>Título</label>
                        <input type="text" class="input-text" ng-model="p.titulo" placeholder="Título pregunta" /> <br />

                        <label>Descripción</label>
                        <input type="text" class="input-text" ng-model="p.nombre" placeholder="Descripción pregunta" /> <br />


                        <label>Tipo de respuesta</label>
                        <div class="options-group">
                            <label><input type="radio" ng-model="p.tipo" value="texto" /> Texto</label>
                            <label><input type="radio" ng-model="p.tipo" value="numero" /> Número</label>
                            <label><input type="radio" ng-model="p.tipo" value="fecha" /> Fecha</label>
                        </div>

                        <label class="checkbox-label">
                            <input type="checkbox" ng-model="p.requerido" />
                            Pregunta obligatoria
                        </label>

                        <button type="button" class="btn-delete"
                                ng-click="eliminarPregunta($index)">
                            Eliminar pregunta
                        </button>

                        <input type="hidden" name="PreguntasJson" value="{{encuesta.preguntas | json}}" />
                    </div>

                    <button type="button" class="btn-add"
                            ng-click="agregarPregunta()">
                        + Agregar Pregunta
                    </button>

                    <button class="btn-submit" type="submit">
                        Crear encuesta
                    </button>

                </div>
            </form>
        }
    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
    <script src="@Url.Content("~/Scripts/utiles.js")"></script>

</body>
</html>
